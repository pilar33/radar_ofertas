DEBUG=True
SECRET_KEY=change-me

# Entorno local principal: SQL Server Docker.
# Render puede usar SQLite temporal solo para demo/staging con RENDER=True y USE_SQLITE_FOR_RENDER=True.
# No subir el .env real al repositorio.
RENDER=False
USE_SQLITE_FOR_RENDER=False
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=
SQLITE_PATH=

USE_EXTERNAL_STORAGE=False
STORAGE_BACKEND=s3
STORAGE_BUCKET_NAME=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_REGION_NAME=
STORAGE_ENDPOINT_URL=
STORAGE_CUSTOM_DOMAIN=
STORAGE_DEFAULT_ACL=private
MEDIA_URL=/media/

ENABLE_HEADLESS_DIAGNOSTIC=False
HEADLESS_PROVIDER=playwright
HEADLESS_TIMEOUT_SECONDS=20
HEADLESS_MAX_PAGES=1
HEADLESS_SCREENSHOTS=False

DB_ENGINE=mssql
DB_NAME=radar_ofertas
DB_USER=sa
DB_PASSWORD=TuPasswordSeguro123
DB_HOST=db
DB_PORT=1433
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_SERVER_CERTIFICATE=yes

MSSQL_SA_PASSWORD=YourStrongPassword123!

OPENAI_API_KEY=
MELI_CLIENT_ID=
MELI_CLIENT_SECRET=
MELI_REDIRECT_URI=http://localhost:8000/mercadolibre/oauth/callback/
MELI_BASE_URL=https://api.mercadolibre.com
MELI_AUTH_BASE_URL=https://auth.mercadolibre.com.ar
MELI_SITE_ID=MLA
MELI_SEARCH_LIMIT_DEFAULT=20
MELI_REQUEST_TIMEOUT=15
MELI_USER_AGENT=radar_ofertas/1.0
MELI_ACCESS_TOKEN=
MELI_REFRESH_TOKEN=
MELI_AFFILIATE_TAG=
MELI_AFFILIATE_BASE_URL=
